{
  "name": "bruno-jesus-portfolio-backend",
  "version": "1.0.0",
  "description": "Production-ready Fastify backend for Bruno Jesus portfolio.",
  "main": "dist/server.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "predev": "npm run sync:frontend",
    "dev": "tsx watch src/server.ts",
    "prebuild": "npm run sync:frontend",
    "build": "tsc",
    "start": "node dist/server.js",
    "postinstall": "prisma generate",
    "sync:frontend": "node scripts/sync-frontend.mjs",
    "security:check": "node scripts/security-check.mjs",
    "lint": "eslint .",
    "test": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "deploy:prepare": "npm run sync:frontend && npm run security:check && npm run prisma:generate && npm run prisma:deploy && npm run build",
    "verify:production": "npm run sync:frontend && npm run security:check && npm run lint && npm test && npm run build && npm audit --audit-level=high"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^6.7.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.3.3",
    "pino": "^9.7.0",
    "prisma": "^6.7.0",
    "resend": "^4.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.25.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
